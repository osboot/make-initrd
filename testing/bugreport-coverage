from __future__ import annotations

import os
import shutil
import subprocess
import sys
import tarfile
import tempfile
from collections import defaultdict
from pathlib import Path

sys.stdout.reconfigure(line_buffering=True)


REQUIRED_PATHS = (
    "dev/devlist",
    "dev/list",
    "etc/blkid.out1",
    "etc/findmnt.out1",
    "etc/fstab",
    "proc/filesystems",
    "proc/mounts",
    "sys",
)


def repo_root() -> Path:
    return Path(__file__).resolve().parent.parent


def find_report_root(base: Path) -> Path | None:
    for candidate in (base / "report", base):
        if all((candidate / rel).exists() for rel in REQUIRED_PATHS):
            return candidate
    return None


def extract_report(src: Path, dst: Path) -> None:
    if src.is_dir():
        shutil.copytree(src, dst, dirs_exist_ok=True, symlinks=True)
        return

    try:
        with tarfile.open(src, "r:*") as tar:
            tar.extractall(dst, filter="data")
            return
    except tarfile.TarError:
        pass

    subprocess.run(["tar", "-xf", str(src), "-C", str(dst)], check=True)


def pick_kernel_dir(root: Path) -> tuple[str | None, Path]:
    modules_root = root / "lib" / "modules"
    if modules_root.is_dir():
        entries = sorted(p for p in modules_root.iterdir() if p.is_dir())
        if entries:
            return entries[0].name, entries[0]

    empty_modules = root / ".coverage-empty-modules"
    (empty_modules / "kernel").mkdir(parents=True, exist_ok=True)
    return None, empty_modules


def run_replay(report_root: Path, kernel: str | None, modules_dir: Path) -> tuple[int, str]:
    root = repo_root()
    env = os.environ.copy()

    etc_dir = report_root / "etc"
    etc_dir.mkdir(parents=True, exist_ok=True)
    initrd_mk = etc_dir / "initrd.mk"
    if not initrd_mk.exists():
        initrd_mk.write_text("AUTODETECT = all\n", encoding="ascii")

    env.update(
        {
            "PATH": f"{root}/.build/dest/usr/bin:{root}/.build/dest/usr/sbin:" + env.get("PATH", ""),
            "MAKE_INITRD_BUG_REPORT": "2",
            "MAKE_INITRD_TESTING": "1",
            "PROCFS_PATH": str(report_root / "proc"),
            "SYSFS_PATH": str(report_root / "sys"),
            "FSTAB": str(report_root / "etc" / "fstab"),
            "INITRD_CONFIG_LIST": str(initrd_mk),
            "FINDMNT_STATE_FILE": str(report_root / "etc" / "findmnt.out1"),
            "BLKID_STATE_FILE": str(report_root / "etc" / "blkid.out1"),
            "DEVLIST_FILE": str(report_root / "dev" / "devlist"),
            "KERNEL_MODULES_DIR": str(modules_dir),
            "GUESS_SUFFIX": "add:guess-root",
            "TEST_GUESS_ACTIONS": "guess/root/action guess-config",
            "RESOLVE_MODALIAS": "",
            "KERNEL_CONFIG": "/dev/null",
            "MAKE_INITRD_TRACE": "1",
            "MAKE_INITRD_TRACE_FORMAT": "tsv",
            "MAKE_INITRD_TRACE_PIDS": "",
            "MAKE_INITRD_TRACE_EXECUTE_PATTERNS": "guess/root/action",
            "MAKE_INITRD_TRACE_SRC_PATTERNS": "features/*/guess/* guess/root/action",
            "MAKE_INITRD_TRACE_RUN_PATTERNS": "*",
        }
    )

    cmd = [str(root / ".build" / "dest" / "usr" / "sbin" / "make-initrd"), "--no-checks", "--no-depmod"]
    if kernel:
        cmd += ["-k", kernel]
    cmd += ["test-guess"]

    proc = subprocess.run(
        cmd,
        cwd=root,
        env=env,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        encoding="utf-8",
        errors="replace",
    )
    return proc.returncode, proc.stdout


def parse_trace(output: str) -> tuple[list[str], list[str], list[str]]:
    sources = set()
    functions = set()
    run_targets = set()

    for line in output.splitlines():
        if not line.startswith("TRACE\t"):
            continue
        fields = line.split("\t", 7)
        if len(fields) != 8:
            continue
        _, kind, _pid, _depth, source, _funcs, entity, _details = fields
        if kind == "filtered":
            continue

        sources.add(source)

        if kind == "function":
            functions.add(f"{source}:{entity}")
        elif kind == "run":
            run_targets.add(entity)

    return sorted(sources), sorted(functions), sorted(run_targets)


def current_guess_sources(root: Path) -> list[str]:
    found = set()

    features_dir = root / "features"
    if features_dir.is_dir():
        for path in features_dir.glob("*/guess/*"):
            if path.is_file():
                found.add(str(path.relative_to(root)))

    guess_dir = root / "guess"
    if guess_dir.is_dir():
        for path in guess_dir.glob("*/action"):
            if path.is_file():
                found.add(str(path.relative_to(root)))

    return sorted(found)


def print_items(title: str, items: list[str], *, empty: str = "none") -> None:
    print(f"{title} ({len(items)}):")
    if not items:
        print(f"  {empty}")
        return

    for item in items:
        print(f"  {item}")


def print_aggregate(title: str, data: dict[str, list[str]]) -> None:
    print(title)
    if not data:
        print("  none")
        return

    for item, names in sorted(data.items(), key=lambda entry: (-len(entry[1]), entry[0])):
        joined = ", ".join(names)
        print(f"  {len(names):2d}  {item}")
        print(f"      reports: {joined}")


def parse_args(argv: list[str]) -> tuple[str, list[Path]]:
    mode = "directory"
    args = list(argv)

    if args and args[0] == "--files":
        mode = "files"
        args.pop(0)
        if args and args[0] == "--":
            args.pop(0)

    if mode == "files":
        if not args:
            print("--files requires at least one bugreport path", file=sys.stderr)
            raise SystemExit(1)
        return mode, [Path(arg) for arg in args]

    reports_dir = Path(args[0]) if args else repo_root() / ".bugreports"
    if not reports_dir.is_dir():
        print(f"{reports_dir}: not a directory", file=sys.stderr)
        raise SystemExit(1)
    return mode, sorted(reports_dir.iterdir())


def main() -> int:
    root = repo_root()
    mode, report_paths = parse_args(sys.argv[1:])
    reports_label = "files" if mode == "files" else str(Path(sys.argv[1]) if len(sys.argv) > 1 else root / ".bugreports")

    aggregate_sources: dict[str, list[str]] = defaultdict(list)
    aggregate_functions: dict[str, list[str]] = defaultdict(list)
    aggregate_run_targets: dict[str, list[str]] = defaultdict(list)
    ok_reports: list[tuple[str, list[str], list[str], list[str]]] = []
    skipped_reports: list[tuple[str, str]] = []
    failed_reports: list[tuple[str, int, list[str]]] = []

    print(f"Bugreport coverage summary for {reports_label}\n")

    for src in report_paths:
        with tempfile.TemporaryDirectory() as tmp:
            tmpdir = Path(tmp)
            extracted = tmpdir / "input"
            extracted.mkdir()

            try:
                extract_report(src, extracted)
            except Exception:
                skipped_reports.append((src.name, "unable to extract"))
                continue

            report_root = find_report_root(extracted)
            if report_root is None:
                skipped_reports.append((src.name, "missing required replay files"))
                continue

            kernel, modules_dir = pick_kernel_dir(report_root)
            rc, output = run_replay(report_root, kernel, modules_dir)
            if rc != 0:
                failed_reports.append((src.name, rc, output.splitlines()[:5]))
                continue

            sources, functions, run_targets = parse_trace(output)
            for source in sources:
                aggregate_sources[source].append(src.name)
            for function in functions:
                aggregate_functions[function].append(src.name)
            for target in run_targets:
                aggregate_run_targets[target].append(src.name)
            ok_reports.append((src.name, sources, functions, run_targets))

    print("Summary:")
    print(f"  OK:   {len(ok_reports)}")
    print(f"  SKIP: {len(skipped_reports)}")
    print(f"  FAIL: {len(failed_reports)}")

    if ok_reports:
        print("\nSuccessful replays:")
        for name, sources, functions, run_targets in ok_reports:
            print(f"\n{name}")
            print_items("  sources", sources)
            print_items("  functions", functions)
            print_items("  run targets", run_targets)

    if skipped_reports:
        print("\nSkipped bugreports:")
        for name, reason in skipped_reports:
            print(f"  {name}: {reason}")

    if failed_reports:
        print("\nFailed bugreports:")
        for name, rc, lines in failed_reports:
            print(f"  {name}: replay exited with rc={rc}")
            for line in lines:
                print(f"    {line}")

    print()
    print_aggregate("Aggregate source coverage:", aggregate_sources)
    if not aggregate_sources:
        return 0

    print()
    print_aggregate("Aggregate function coverage:", aggregate_functions)
    print()
    print_aggregate("Aggregate run target coverage:", aggregate_run_targets)

    covered = set(aggregate_sources)
    uncovered = [source for source in current_guess_sources(root) if source not in covered]
    print()
    print_items("Uncovered guess sources", uncovered)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
