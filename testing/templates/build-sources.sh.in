#!/bin/bash -efux

cd @BUILDDIR@
rc=0

@PRE_CONFIGURE@
./autogen.sh
./configure \
	--enable-local-build \
	--with-runtimedir=/lib/initrd1 || rc=$?

if [ "$rc" != 0 ]; then
	echo '========================================='
	cat config.log
	exit 1
fi

make || rc=$?

if [ "$rc" != 0 ]; then
	echo '========================================='
	cat config.log
	exit 1
fi
